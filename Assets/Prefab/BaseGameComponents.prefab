--- !u!114 &7574112646392885113
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 5620176167719096081}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b89dbc796af2b654895808f014f273b9, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  pauseMenuGroupInfo:
  - groupLabel: Resolution
    groupType: 8
    groupDescription: 'Changes the resolution of the game. Choose a suitable resolution
      in this window.

      This only effects Fullscreen mode.'
  - groupLabel: Fullscreen Mode
    groupType: 4
    groupDescription: Whether or not the game will run in fullscreen.
  - groupLabel: MSAA (Anti-Aliasing) Samples
    groupType: 8
    groupDescription: How many samples MSAA will use for anti-aliasing. Use this
      to smooth out jagged lines at the cost of performance.
  - groupLabel: Render Scale
    groupType: 2
    groupDescription: How much the current resolution is scaled up for rendering.
      Set this to a lower value for a lower render resolution.
  - groupLabel: VSync
    groupType: 4
    groupDescription: Whether or not VSync (Vertical Sync) is used. This will limit
      the game to run at the monitor's refresh rate.
  - groupLabel: Frame Limit
    groupType: 1
    groupDescription: 'A custom framerate limit.

      Set this to a positive integer
      for a custom limit that overrides your VSync setting (Minimum 30 FPS).

      Set
      this to zero (or negative integer) for no custom limit.'
  moduleName: Graphics
  pauseMenuGroupPrefab: {fileID: 7675434567367093276, guid: 13e7f516926cf794eb86a93239b53e65, type: 3}
  groupContentRectTransform: {fileID: 2617089836302549600}
