  m_Script: {fileID: 11500000, guid: bef162da1c80b3b408e5f3fc01ccb767, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  pauseMenuGroupInfo:
  - groupLabel: Audio Offset (ms)
    groupType: 1
    groupDescription: 'Adjusts the offset for better synchronisation.

      To calibrate,
      go to the offset calibration screen in the Main Menu.'
  - groupLabel: Mouse Sensitivity Scale
    groupType: 34
    groupDescription: 'Adjusts the game cursor sensitivity by scaling. The default
      value is 1.

      To use raw mouse input (no mouse acceleration), turn it
      off in your OS settings.

'
  - groupLabel: Use Prescheduled Hitsounds
    groupType: 4
    groupDescription: 'Whether or not prescheduled hitsounds are used. This will
      play hitsounds as if you are playing perfectly.

      Turn this setting on
      if you have a high audio latency.'
  - groupLabel: Show FPS
    groupType: 4
    groupDescription: 'Shows the FPS of the game in the bottom-right corner.

      You
      can hover over the FPS counter to hide it temporarily (Only works outside of
      pause menu).'
  - groupLabel: Song Volume
    groupType: 2
    groupDescription: 
  - groupLabel: Hitsound Volme
    groupType: 2
    groupDescription: 
  moduleName: Global
  pauseMenuGroupPrefab: {fileID: 7675434567367093276, guid: 13e7f516926cf794eb86a93239b53e65, type: 3}
  groupContentRectTransform: {fileID: 2617089836302549600}
--- !u!114 &4681279834613601856
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 5620176167719096081}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: cc0f448bf7d75e34cad29b7fd1429e0d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  pauseMenuGroupInfo:
  - groupLabel: Approach Speed
    groupType: 1
    groupDescription: 'Controls the speed at which notes approach.

      Increase
      speed if notes are too dense but at the cost of making notes harder to track.'
  - groupLabel: Lookahead Time
    groupType: 1
    groupDescription: 'Controls how far in time we lookahead for notes to be visible.

      Set
      this to a comfortable value, where you have enough time to react without cluttering
      the screen.


'
  - groupLabel: Rebind Red Key
    groupType: 48
    groupDescription: Set the current keybind to become Red (Hitbox Type A).
  - groupLabel: Rebind Blue Key
    groupType: 48
    groupDescription: Set the current keybind to become Blue (Hitbox Type B).
  moduleName: Gameplay
  pauseMenuGroupPrefab: {fileID: 7675434567367093276, guid: 13e7f516926cf794eb86a93239b53e65, type: 3}
  groupContentRectTransform: {fileID: 2617089836302549600}
